# Copier vers .env.test (non versionné) pour les tests E2E Playwright
# PostgreSQL test reproductible : npm run db:test:up

TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/chantiers360_v2_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/chantiers360_v2_test
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Démarrage rapide (Docker requis) :
#   cp .env.test.example .env.test
#   npm run test:e2e:full
#
# Ou étape par étape :
#   npm run db:test:up
#   npm run db:test:migrate
#   npm run test:e2e
#
# Arrêt (conserve le volume de données) :
#   npm run db:test:down
#
# Arrêt + suppression volume (destructif) :
#   npm run db:test:down:clean
