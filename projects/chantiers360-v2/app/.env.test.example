# Copier vers .env.test (non versionné) pour les tests E2E Playwright
# Base dédiée recommandée — distincte de la DB dev si possible

TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chantiers360_v2_test
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Prérequis :
# 1. Créer la base : createdb chantiers360_v2_test
# 2. Appliquer migrations : DATABASE_URL=$TEST_DATABASE_URL npm run db:migrate
# 3. Lancer : npm run test:e2e
