{
  "name": "chantiers360-v2",
  "private": true,
  "version": "0.5.0-inc05",
  "description": "Chantiers360 v2 — delivery INC-05 (prochaines actions dérivées)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:test:down": "docker compose -f docker-compose.test.yml down",
    "db:test:down:clean": "docker compose -f docker-compose.test.yml down -v",
    "db:test:migrate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/chantiers360_v2_test drizzle-kit migrate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:full": "npm run db:test:up && npm run db:test:migrate && npm run test:e2e"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "next": "^15.3.3",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.21",
    "dotenv": "^16.5.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
