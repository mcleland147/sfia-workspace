{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sfia.local/schemas/v3-modeled/policy/enforcement-rule.schema.json",
  "title": "EnforcementRule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ruleId",
    "scope",
    "trigger",
    "condition",
    "enforcementLevel",
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0-d1"
    },
    "ruleId": {
      "type": "string",
      "pattern": "^D1-[A-Z0-9\\-]+$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "project",
        "cycle",
        "session",
        "security",
        "transition"
      ]
    },
    "trigger": {
      "type": "string"
    },
    "condition": {
      "type": "string"
    },
    "enforcementLevel": {
      "type": "string",
      "enum": [
        "E0",
        "E1",
        "E2",
        "E3",
        "E4"
      ]
    },
    "userExplanationKey": {
      "type": "string"
    },
    "correctionOptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredRole": {
      "type": ["string", "null"]
    },
    "reserveType": {
      "type": [
        "string",
        "null"
      ]
    },
    "decisionRequestType": {
      "type": [
        "string",
        "null"
      ]
    },
    "auditEventType": {
      "type": "string"
    },
    "effect": {
      "type": "string"
    },
    "testCases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
