{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sfia.local/schemas/v3-modeled/v3-native-option-a/decision/human-decision.schema.json",
  "title": "HumanDecision",
  "description": "Explicit human decision. Chat utterance alone is not a decision. Distinct from Confirmation and Recommendation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "decisionId",
    "projectId",
    "subject",
    "options",
    "selectedOptionId",
    "actor",
    "authority",
    "status",
    "effectiveAt",
    "reversible"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0-oa"
    },
    "decisionId": {
      "$ref": "../common/identifier.schema.json"
    },
    "projectId": {
      "$ref": "../common/identifier.schema.json"
    },
    "cycleInstanceId": {
      "$ref": "../common/identifier.schema.json"
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "optionId",
          "label"
        ],
        "properties": {
          "optionId": {
            "$ref": "../common/identifier.schema.json"
          },
          "label": {
            "type": "string"
          },
          "impacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended": {
            "type": "boolean"
          }
        }
      }
    },
    "selectedOptionId": {
      "$ref": "../common/identifier.schema.json"
    },
    "actor": {
      "$ref": "../common/actor-reference.schema.json"
    },
    "authority": {
      "type": "string",
      "enum": [
        "morris",
        "delegated",
        "system_non_structuring"
      ]
    },
    "scope": {
      "type": "string"
    },
    "reservations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reservationId",
          "statement"
        ],
        "properties": {
          "reservationId": {
            "$ref": "../common/identifier.schema.json"
          },
          "statement": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "rationale": {
      "type": "string"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "reversible": {
      "type": "boolean"
    },
    "effectiveAt": {
      "$ref": "../common/timestamp.schema.json"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "required",
        "accepted",
        "refused",
        "amended",
        "superseded",
        "revoked"
      ]
    },
    "supersedes": {
      "$ref": "../common/identifier.schema.json"
    },
    "provenance": {
      "$ref": "../common/provenance-record.schema.json"
    }
  }
}
