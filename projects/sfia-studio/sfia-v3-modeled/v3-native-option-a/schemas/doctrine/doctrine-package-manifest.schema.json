{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sfia.local/schemas/v3-modeled/v3-native-option-a/doctrine/doctrine-package-manifest.schema.json",
  "title": "DoctrinePackageManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "doctrinePackageId",
    "version",
    "digest",
    "status",
    "sources",
    "publishedAt",
    "compatibility"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0-oa"
    },
    "doctrinePackageId": {
      "$ref": "../common/identifier.schema.json"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "$ref": "../common/digest.schema.json"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "deprecated",
        "revoked"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "doctrineSourceRef",
          "kind"
        ],
        "properties": {
          "doctrineSourceRef": {
            "$ref": "../common/identifier.schema.json"
          },
          "kind": {
            "type": "string",
            "enum": [
              "framing",
              "design",
              "modeled",
              "ux",
              "other"
            ]
          },
          "label": {
            "type": "string"
          },
          "digest": {
            "$ref": "../common/digest.schema.json"
          }
        }
      }
    },
    "allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publishedAt": {
      "$ref": "../common/timestamp.schema.json"
    },
    "freshness": {
      "type": "string",
      "enum": [
        "current",
        "aging",
        "stale"
      ]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "studioNativeV3"
      ],
      "properties": {
        "studioNativeV3": {
          "type": "boolean",
          "const": true
        },
        "legacyV26Fallback": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "provenance": {
      "$ref": "../common/provenance-record.schema.json"
    }
  }
}
