{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sfia.local/schemas/v3-modeled/v3-native-option-a/cycle/project-trajectory.schema.json",
  "title": "ProjectTrajectory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "trajectoryId",
    "projectId",
    "version",
    "status",
    "steps"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0-oa"
    },
    "trajectoryId": {
      "$ref": "../common/identifier.schema.json"
    },
    "projectId": {
      "$ref": "../common/identifier.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "validated",
        "active",
        "stale",
        "superseded"
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "order",
          "label",
          "state"
        ],
        "properties": {
          "stepId": {
            "$ref": "../common/identifier.schema.json"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "label": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "$ref": "../common/identifier.schema.json"
            }
          },
          "gate": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "pending",
              "active",
              "blocked",
              "done",
              "skipped"
            ]
          },
          "exitCriteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reservations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "supersedesTrajectoryVersion": {
      "type": "integer",
      "minimum": 1
    }
  }
}
