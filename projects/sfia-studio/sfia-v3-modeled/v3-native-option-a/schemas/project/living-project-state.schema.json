{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sfia.local/schemas/v3-modeled/v3-native-option-a/project/living-project-state.schema.json",
  "title": "LivingProjectState",
  "description": "FA-OA-01: unique logical aggregate owned by domain C. UI panel is a projection only. Mutations create new versions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "lpsVersionId",
    "projectId",
    "version",
    "status",
    "objective",
    "createdAt",
    "createdBy",
    "doctrinePackageRef"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0-oa"
    },
    "lpsVersionId": {
      "$ref": "../common/identifier.schema.json"
    },
    "projectId": {
      "$ref": "../common/identifier.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "supersedesLpsVersionId": {
      "$ref": "../common/identifier.schema.json"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "stale",
        "conflict",
        "superseded"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "doctrinePackageRef": {
      "$ref": "../doctrine/doctrine-package-ref.schema.json"
    },
    "ckcResolutionRef": {
      "$ref": "../common/identifier.schema.json"
    },
    "activeCycleInstanceId": {
      "$ref": "../common/identifier.schema.json"
    },
    "trajectoryId": {
      "$ref": "../common/identifier.schema.json"
    },
    "trajectoryVersion": {
      "type": "integer",
      "minimum": 1
    },
    "epistemicItemIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "decisionIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "reservationIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "contradictionIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "evidenceIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "debtItemIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "riskItemIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "reviewBundleIds": {
      "type": "array",
      "items": {
        "$ref": "../common/identifier.schema.json"
      }
    },
    "maturityAssessmentId": {
      "$ref": "../common/identifier.schema.json"
    },
    "nextStep": {
      "type": "string"
    },
    "createdAt": {
      "$ref": "../common/timestamp.schema.json"
    },
    "createdBy": {
      "$ref": "../common/actor-reference.schema.json"
    },
    "correlationId": {
      "$ref": "../common/identifier.schema.json"
    },
    "provenance": {
      "$ref": "../common/provenance-record.schema.json"
    },
    "uiOwnership": {
      "type": "boolean",
      "const": false,
      "description": "Panel never owns state"
    }
  }
}
