{
  "name": "@sfia-studio/poc-s1-harness",
  "private": true,
  "version": "0.1.0",
  "description": "SFIA Studio POC S1 harness-only orchestrator (local, fail-closed, no remote Git writes; Cursor/GPT fixtures default; experimental OpenAI/Cursor spikes behind flags)",
  "type": "module",
  "bin": {
    "sfia-poc-s1": "./dist/cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "spike:cursor-real": "tsx spikes/cursor-real/run-spike.ts",
    "spike:gpt-openai": "tsx spikes/gpt-openai/run-spike.ts",
    "spike:e2e-gpt-cursor": "tsx spikes/e2e-gpt-cursor/run-e2e.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
