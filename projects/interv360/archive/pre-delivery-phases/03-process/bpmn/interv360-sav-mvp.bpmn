      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RechercherDoublonPotentiel_di" bpmnElement="Task_RechercherDoublonPotentiel">
        <dc:Bounds x="740" y="530" width="120" height="80"/>
      </bpmndi:BPMNShape>
