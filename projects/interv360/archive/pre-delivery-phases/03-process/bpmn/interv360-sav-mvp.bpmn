<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Interv360SavMvp" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.31.0">
  <bpmn:collaboration id="Collaboration_Interv360SavMvp">
    <bpmn:participant id="Participant_Interv360SavMvp" name="Interv360 SAV MVP" processRef="Process_Interv360SavMvp"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Interv360SavMvp" name="Interv360 SAV MVP" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Interv360SavMvp">
      <bpmn:lane id="Lane_Client" name="Client / canal entrant">
        <bpmn:flowNodeRef>StartEvent_DemandeSavRecue</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ManagerSav" name="Manager SAV">
        <bpmn:flowNodeRef>Task_VerifierDonneesMinimales</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DonneesSuffisantes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CompleterMaintenirAQualifier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DoublonPotentiel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArbitrerDoublon</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QualifierDemande</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PlanifierIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AffecterTechnicien</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RenseignerMotifAbsenceSignature</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Technicien" name="Technicien">
        <bpmn:flowNodeRef>Task_ConsulterInterventionPlanifiee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DemarrerIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InterventionRealisable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PasserEnAttenteClient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReprendreIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RealiserIntervention</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RedigerCompteRenduWeb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SignatureClient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CapturerSignature</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Interv360" name="Interv360">
        <bpmn:flowNodeRef>Task_CreerEnregistrerDemande</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RechercherDoublonPotentiel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CloreIntervention</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CrmSimule" name="CRM simulé / intégration">
        <bpmn:flowNodeRef>Task_SynchroniserClotureCrm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SynchronisationReussie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SignalerAnomalieIntegration</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dashboard" name="Dashboard / pilotage">
        <bpmn:flowNodeRef>Task_MettreAJourDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_InterventionCloturee</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_DemandeSavRecue" name="Demande SAV reçue">
      <bpmn:outgoing>Flow_Start_Creer</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_CreerEnregistrerDemande" name="Créer ou enregistrer la demande">
      <bpmn:incoming>Flow_Start_Creer</bpmn:incoming>
      <bpmn:outgoing>Flow_Creer_Verifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_VerifierDonneesMinimales" name="Vérifier les données minimales">
      <bpmn:incoming>Flow_Creer_Verifier</bpmn:incoming>
      <bpmn:incoming>Flow_Completer_Verifier</bpmn:incoming>
      <bpmn:outgoing>Flow_Verifier_GatewayDonnees</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DonneesSuffisantes" name="Données suffisantes ?" default="Flow_Donnees_Non">
      <bpmn:incoming>Flow_Verifier_GatewayDonnees</bpmn:incoming>
      <bpmn:outgoing>Flow_Donnees_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Donnees_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CompleterMaintenirAQualifier" name="Compléter / maintenir à qualifier">
      <bpmn:incoming>Flow_Donnees_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_Completer_Verifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RechercherDoublonPotentiel" name="Rechercher doublon potentiel">
      <bpmn:incoming>Flow_Donnees_Oui</bpmn:incoming>
      <bpmn:outgoing>Flow_Rechercher_GatewayDoublon</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_DoublonPotentiel" name="Doublon potentiel détecté ?" default="Flow_Doublon_Non">
      <bpmn:incoming>Flow_Rechercher_GatewayDoublon</bpmn:incoming>
      <bpmn:outgoing>Flow_Doublon_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Doublon_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ArbitrerDoublon" name="Arbitrer le doublon et décider la suite">
      <bpmn:incoming>Flow_Doublon_Oui</bpmn:incoming>
      <bpmn:outgoing>Flow_Arbitrer_Qualifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QualifierDemande" name="Qualifier la demande">
      <bpmn:incoming>Flow_Doublon_Non</bpmn:incoming>
      <bpmn:incoming>Flow_Arbitrer_Qualifier</bpmn:incoming>
      <bpmn:outgoing>Flow_Qualifier_Planifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PlanifierIntervention" name="Planifier l'intervention">
      <bpmn:incoming>Flow_Qualifier_Planifier</bpmn:incoming>
      <bpmn:outgoing>Flow_Planifier_Affecter</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AffecterTechnicien" name="Affecter un technicien">
      <bpmn:incoming>Flow_Planifier_Affecter</bpmn:incoming>
      <bpmn:outgoing>Flow_Affecter_Consulter</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConsulterInterventionPlanifiee" name="Consulter l'intervention planifiée">
      <bpmn:incoming>Flow_Affecter_Consulter</bpmn:incoming>
      <bpmn:outgoing>Flow_Consulter_Demarrer</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DemarrerIntervention" name="Démarrer l'intervention">
      <bpmn:incoming>Flow_Consulter_Demarrer</bpmn:incoming>
      <bpmn:outgoing>Flow_Demarrer_GatewayRealisable</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_InterventionRealisable" name="Intervention réalisable ?" default="Flow_Realisable_Non">
      <bpmn:incoming>Flow_Demarrer_GatewayRealisable</bpmn:incoming>
      <bpmn:outgoing>Flow_Realisable_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Realisable_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_PasserEnAttenteClient" name="Passer en attente client">
      <bpmn:incoming>Flow_Realisable_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_Attente_Reprendre</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReprendreIntervention" name="Reprendre l'intervention">
      <bpmn:incoming>Flow_Attente_Reprendre</bpmn:incoming>
      <bpmn:outgoing>Flow_Reprendre_Realiser</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RealiserIntervention" name="Réaliser l'intervention">
      <bpmn:incoming>Flow_Realisable_Oui</bpmn:incoming>
      <bpmn:incoming>Flow_Reprendre_Realiser</bpmn:incoming>
      <bpmn:outgoing>Flow_Realiser_CR</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RedigerCompteRenduWeb" name="Rédiger le compte rendu web">
      <bpmn:incoming>Flow_Realiser_CR</bpmn:incoming>
      <bpmn:outgoing>Flow_CR_GatewaySignature</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SignatureClient" name="Signature client disponible ?" default="Flow_Signature_Non">
      <bpmn:incoming>Flow_CR_GatewaySignature</bpmn:incoming>
      <bpmn:outgoing>Flow_Signature_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Signature_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CapturerSignature" name="Capturer la signature">
      <bpmn:incoming>Flow_Signature_Oui</bpmn:incoming>
      <bpmn:outgoing>Flow_Capturer_Clore</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RenseignerMotifAbsenceSignature" name="Renseigner le motif d'absence de signature">
      <bpmn:incoming>Flow_Signature_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_Motif_Clore</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CloreIntervention" name="Clôturer l'intervention">
      <bpmn:incoming>Flow_Capturer_Clore</bpmn:incoming>
      <bpmn:incoming>Flow_Motif_Clore</bpmn:incoming>
      <bpmn:outgoing>Flow_Clore_Sync</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SynchroniserClotureCrm" name="Synchroniser la clôture vers CRM simulé">
      <bpmn:incoming>Flow_Clore_Sync</bpmn:incoming>
      <bpmn:outgoing>Flow_Sync_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SynchronisationReussie" name="Synchronisation réussie ?" default="Flow_Sync_Non">
      <bpmn:incoming>Flow_Sync_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Sync_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sync_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SignalerAnomalieIntegration" name="Signaler anomalie d'intégration">
      <bpmn:incoming>Flow_Sync_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_Anomalie_Dashboard</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_MettreAJourDashboard" name="Mettre à jour le dashboard">
      <bpmn:incoming>Flow_Sync_Oui</bpmn:incoming>
      <bpmn:incoming>Flow_Anomalie_Dashboard</bpmn:incoming>
      <bpmn:outgoing>Flow_Dashboard_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_InterventionCloturee" name="Intervention clôturée localement">
      <bpmn:incoming>Flow_Dashboard_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Creer" sourceRef="StartEvent_DemandeSavRecue" targetRef="Task_CreerEnregistrerDemande"/>
    <bpmn:sequenceFlow id="Flow_Creer_Verifier" sourceRef="Task_CreerEnregistrerDemande" targetRef="Task_VerifierDonneesMinimales"/>
    <bpmn:sequenceFlow id="Flow_Verifier_GatewayDonnees" sourceRef="Task_VerifierDonneesMinimales" targetRef="Gateway_DonneesSuffisantes"/>
    <bpmn:sequenceFlow id="Flow_Donnees_Oui" sourceRef="Gateway_DonneesSuffisantes" targetRef="Task_RechercherDoublonPotentiel" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Donnees_Non" sourceRef="Gateway_DonneesSuffisantes" targetRef="Task_CompleterMaintenirAQualifier" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Completer_Verifier" sourceRef="Task_CompleterMaintenirAQualifier" targetRef="Task_VerifierDonneesMinimales"/>
    <bpmn:sequenceFlow id="Flow_Rechercher_GatewayDoublon" sourceRef="Task_RechercherDoublonPotentiel" targetRef="Gateway_DoublonPotentiel"/>
    <bpmn:sequenceFlow id="Flow_Doublon_Oui" sourceRef="Gateway_DoublonPotentiel" targetRef="Task_ArbitrerDoublon" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Doublon_Non" sourceRef="Gateway_DoublonPotentiel" targetRef="Task_QualifierDemande" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Arbitrer_Qualifier" sourceRef="Task_ArbitrerDoublon" targetRef="Task_QualifierDemande"/>
    <bpmn:sequenceFlow id="Flow_Qualifier_Planifier" sourceRef="Task_QualifierDemande" targetRef="Task_PlanifierIntervention"/>
    <bpmn:sequenceFlow id="Flow_Planifier_Affecter" sourceRef="Task_PlanifierIntervention" targetRef="Task_AffecterTechnicien"/>
    <bpmn:sequenceFlow id="Flow_Affecter_Consulter" sourceRef="Task_AffecterTechnicien" targetRef="Task_ConsulterInterventionPlanifiee"/>
    <bpmn:sequenceFlow id="Flow_Consulter_Demarrer" sourceRef="Task_ConsulterInterventionPlanifiee" targetRef="Task_DemarrerIntervention"/>
    <bpmn:sequenceFlow id="Flow_Demarrer_GatewayRealisable" sourceRef="Task_DemarrerIntervention" targetRef="Gateway_InterventionRealisable"/>
    <bpmn:sequenceFlow id="Flow_Realisable_Oui" sourceRef="Gateway_InterventionRealisable" targetRef="Task_RealiserIntervention" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Realisable_Non" sourceRef="Gateway_InterventionRealisable" targetRef="Task_PasserEnAttenteClient" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Attente_Reprendre" sourceRef="Task_PasserEnAttenteClient" targetRef="Task_ReprendreIntervention"/>
    <bpmn:sequenceFlow id="Flow_Reprendre_Realiser" sourceRef="Task_ReprendreIntervention" targetRef="Task_RealiserIntervention"/>
    <bpmn:sequenceFlow id="Flow_Realiser_CR" sourceRef="Task_RealiserIntervention" targetRef="Task_RedigerCompteRenduWeb"/>
    <bpmn:sequenceFlow id="Flow_CR_GatewaySignature" sourceRef="Task_RedigerCompteRenduWeb" targetRef="Gateway_SignatureClient"/>
    <bpmn:sequenceFlow id="Flow_Signature_Oui" sourceRef="Gateway_SignatureClient" targetRef="Task_CapturerSignature" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Signature_Non" sourceRef="Gateway_SignatureClient" targetRef="Task_RenseignerMotifAbsenceSignature" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Capturer_Clore" sourceRef="Task_CapturerSignature" targetRef="Task_CloreIntervention"/>
    <bpmn:sequenceFlow id="Flow_Motif_Clore" sourceRef="Task_RenseignerMotifAbsenceSignature" targetRef="Task_CloreIntervention"/>
    <bpmn:sequenceFlow id="Flow_Clore_Sync" sourceRef="Task_CloreIntervention" targetRef="Task_SynchroniserClotureCrm"/>
    <bpmn:sequenceFlow id="Flow_Sync_Gateway" sourceRef="Task_SynchroniserClotureCrm" targetRef="Gateway_SynchronisationReussie"/>
    <bpmn:sequenceFlow id="Flow_Sync_Oui" sourceRef="Gateway_SynchronisationReussie" targetRef="Task_MettreAJourDashboard" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Sync_Non" sourceRef="Gateway_SynchronisationReussie" targetRef="Task_SignalerAnomalieIntegration" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Anomalie_Dashboard" sourceRef="Task_SignalerAnomalieIntegration" targetRef="Task_MettreAJourDashboard"/>
    <bpmn:sequenceFlow id="Flow_Dashboard_End" sourceRef="Task_MettreAJourDashboard" targetRef="EndEvent_InterventionCloturee"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Interv360SavMvp">
    <bpmndi:BPMNPlane id="BPMNPlane_Interv360SavMvp" bpmnElement="Collaboration_Interv360SavMvp">
      <bpmndi:BPMNShape id="Participant_di" bpmnElement="Participant_Interv360SavMvp" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3700" height="900"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Client_di" bpmnElement="Lane_Client" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ManagerSav_di" bpmnElement="Lane_ManagerSav" isHorizontal="true">
        <dc:Bounds x="190" y="230" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Technicien_di" bpmnElement="Lane_Technicien" isHorizontal="true">
        <dc:Bounds x="190" y="380" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Interv360_di" bpmnElement="Lane_Interv360" isHorizontal="true">
        <dc:Bounds x="190" y="530" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_CrmSimule_di" bpmnElement="Lane_CrmSimule" isHorizontal="true">
        <dc:Bounds x="190" y="680" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Dashboard_di" bpmnElement="Lane_Dashboard" isHorizontal="true">
        <dc:Bounds x="190" y="830" width="3670" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_DemandeSavRecue_di" bpmnElement="StartEvent_DemandeSavRecue">
        <dc:Bounds x="220" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreerEnregistrerDemande_di" bpmnElement="Task_CreerEnregistrerDemande">
