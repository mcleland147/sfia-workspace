        <dc:Bounds x="1480" y="230" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConsulterInterventionPlanifiee_di" bpmnElement="Task_ConsulterInterventionPlanifiee">
        <dc:Bounds x="1640" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DemarrerIntervention_di" bpmnElement="Task_DemarrerIntervention">
        <dc:Bounds x="1800" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InterventionRealisable_di" bpmnElement="Gateway_InterventionRealisable" isMarkerVisible="true">
        <dc:Bounds x="1965" y="407" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PasserEnAttenteClient_di" bpmnElement="Task_PasserEnAttenteClient">
        <dc:Bounds x="2060" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReprendreIntervention_di" bpmnElement="Task_ReprendreIntervention">
        <dc:Bounds x="2200" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RealiserIntervention_di" bpmnElement="Task_RealiserIntervention">
        <dc:Bounds x="2340" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RedigerCompteRenduWeb_di" bpmnElement="Task_RedigerCompteRenduWeb">
        <dc:Bounds x="2480" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SignatureClient_di" bpmnElement="Gateway_SignatureClient" isMarkerVisible="true">
        <dc:Bounds x="2615" y="407" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CapturerSignature_di" bpmnElement="Task_CapturerSignature">
        <dc:Bounds x="2710" y="380" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RenseignerMotifAbsenceSignature_di" bpmnElement="Task_RenseignerMotifAbsenceSignature">
        <dc:Bounds x="2710" y="230" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CloreIntervention_di" bpmnElement="Task_CloreIntervention">
        <dc:Bounds x="2850" y="530" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SynchroniserClotureCrm_di" bpmnElement="Task_SynchroniserClotureCrm">
        <dc:Bounds x="3010" y="680" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SynchronisationReussie_di" bpmnElement="Gateway_SynchronisationReussie" isMarkerVisible="true">
        <dc:Bounds x="3175" y="707" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SignalerAnomalieIntegration_di" bpmnElement="Task_SignalerAnomalieIntegration">
