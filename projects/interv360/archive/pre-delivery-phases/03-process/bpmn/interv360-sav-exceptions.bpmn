<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Interv360SavExceptions" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.31.0">
  <bpmn:collaboration id="Collaboration_Interv360SavExceptions">
    <bpmn:participant id="Participant_Interv360SavExceptions" name="Interv360 SAV Exceptions" processRef="Process_Interv360_SAV_Exceptions"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Interv360_SAV_Exceptions" name="Interv360 SAV Exceptions" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Exceptions">
      <bpmn:lane id="Lane_ManagerSav" name="Manager SAV">
        <bpmn:flowNodeRef>Group_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S1_Identify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S1_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Group_S2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S2_Compare</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_S2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S2_Mark</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S2_Treated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S2_Continue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S2_Done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Group_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Group_S4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S4_Analyze</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S4_Replan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Group_S5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Technicien" name="Technicien">
        <bpmn:flowNodeRef>StartEvent_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S3_Wait</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S3_Reason</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S3_Maintain</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S3_Resume</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_S5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S5_Select</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S5_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S5_Validate</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Interv360" name="Interv360">
        <bpmn:flowNodeRef>Task_S1_Update</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_S2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S2_Display</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S3_Dashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_S5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S5_Close</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dashboard" name="Dashboard / pilotage">
        <bpmn:flowNodeRef>StartEvent_S4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_S4_Signal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_S4</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:group id="Group_S1" name="1. Données insuffisantes"/>
    <bpmn:group id="Group_S2" name="2. Doublon potentiel"/>
    <bpmn:group id="Group_S3" name="3. Attente client"/>
    <bpmn:group id="Group_S4" name="4. Retard (indicateur pilotage)"/>
    <bpmn:group id="Group_S5" name="5. Clôture sans signature"/>
    <bpmn:startEvent id="StartEvent_S1" name="Données insuffisantes détectées">
      <bpmn:outgoing>Flow_S1_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_S1_Identify" name="Identifier les données manquantes">
      <bpmn:incoming>Flow_S1_1</bpmn:incoming>
      <bpmn:incoming>Flow_S1_6</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S1_Complete" name="Compléter la demande">
      <bpmn:incoming>Flow_S1_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S1_Update" name="Mettre à jour la demande">
      <bpmn:incoming>Flow_S1_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_S1" name="Données minimales complètes ?" default="Flow_S1_6">
      <bpmn:incoming>Flow_S1_4</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_S1_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_S1" name="Demande prête à qualifier">
      <bpmn:incoming>Flow_S1_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_S2" name="Doublon potentiel détecté">
      <bpmn:outgoing>Flow_S2_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_S2_Display" name="Afficher les demandes proches">
      <bpmn:incoming>Flow_S2_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S2_Compare" name="Comparer les demandes">
      <bpmn:incoming>Flow_S2_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_S2" name="Doublon confirmé ?" default="Flow_S2_5">
      <bpmn:incoming>Flow_S2_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_S2_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_S2_Mark" name="Marquer / rapprocher comme doublon">
      <bpmn:incoming>Flow_S2_4</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_S2_Treated" name="Doublon traité">
      <bpmn:incoming>Flow_S2_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_S2_Continue" name="Continuer la qualification">
      <bpmn:incoming>Flow_S2_5</bpmn:incoming>
      <bpmn:outgoing>Flow_S2_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_S2_Done" name="Arbitrage doublon terminé">
      <bpmn:incoming>Flow_S2_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_S3" name="Blocage client identifié">
      <bpmn:outgoing>Flow_S3_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_S3_Wait" name="Passer en attente client">
      <bpmn:incoming>Flow_S3_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S3_Reason" name="Renseigner le motif d'attente">
      <bpmn:incoming>Flow_S3_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S3_Dashboard" name="Rendre l'attente visible au dashboard">
      <bpmn:incoming>Flow_S3_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_S3" name="Blocage levé ?" default="Flow_S3_6">
      <bpmn:incoming>Flow_S3_4</bpmn:incoming>
      <bpmn:incoming>Flow_S3_7</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_S3_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_S3_Maintain" name="Maintenir en attente client">
      <bpmn:incoming>Flow_S3_6</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S3_Resume" name="Reprendre l'intervention">
      <bpmn:incoming>Flow_S3_5</bpmn:incoming>
      <bpmn:outgoing>Flow_S3_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_S3" name="Intervention reprise">
      <bpmn:incoming>Flow_S3_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_S4" name="Échéance dépassée">
      <bpmn:outgoing>Flow_S4_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_S4_Signal" name="Signaler le retard">
      <bpmn:incoming>Flow_S4_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S4_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S4_Analyze" name="Analyser la cause du retard">
      <bpmn:incoming>Flow_S4_2</bpmn:incoming>
      <bpmn:outgoing>Flow_S4_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S4_Replan" name="Réajuster la planification">
      <bpmn:incoming>Flow_S4_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S4_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_S4" name="Retard pris en compte">
      <bpmn:incoming>Flow_S4_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="StartEvent_S5" name="Signature client indisponible">
      <bpmn:outgoing>Flow_S5_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_S5_Select" name="Sélectionner un motif d'absence">
      <bpmn:incoming>Flow_S5_1</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_S5" name="Motif suffisant ?" default="Flow_S5_4">
      <bpmn:incoming>Flow_S5_2</bpmn:incoming>
      <bpmn:incoming>Flow_S5_5</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_S5_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_S5_Complete" name="Compléter le motif">
      <bpmn:incoming>Flow_S5_4</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S5_Validate" name="Valider le compte rendu">
      <bpmn:incoming>Flow_S5_3</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_S5_Close" name="Clôturer sans signature">
      <bpmn:incoming>Flow_S5_6</bpmn:incoming>
      <bpmn:outgoing>Flow_S5_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_S5" name="Intervention clôturée sans signature">
      <bpmn:incoming>Flow_S5_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_Motifs">
      <bpmn:text>Motifs absence signature : Client absent ; Signature refusée ; Signature non applicable ; Contrainte terrain ; Autre motif à préciser</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:sequenceFlow id="Flow_S1_1" sourceRef="StartEvent_S1" targetRef="Task_S1_Identify"/>
    <bpmn:sequenceFlow id="Flow_S1_2" sourceRef="Task_S1_Identify" targetRef="Task_S1_Complete"/>
    <bpmn:sequenceFlow id="Flow_S1_3" sourceRef="Task_S1_Complete" targetRef="Task_S1_Update"/>
    <bpmn:sequenceFlow id="Flow_S1_4" sourceRef="Task_S1_Update" targetRef="Gateway_S1"/>
    <bpmn:sequenceFlow id="Flow_S1_5" sourceRef="Gateway_S1" targetRef="EndEvent_S1" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_S1_6" sourceRef="Gateway_S1" targetRef="Task_S1_Identify" name="Non"/>
    <bpmn:sequenceFlow id="Flow_S2_1" sourceRef="StartEvent_S2" targetRef="Task_S2_Display"/>
    <bpmn:sequenceFlow id="Flow_S2_2" sourceRef="Task_S2_Display" targetRef="Task_S2_Compare"/>
    <bpmn:sequenceFlow id="Flow_S2_3" sourceRef="Task_S2_Compare" targetRef="Gateway_S2"/>
    <bpmn:sequenceFlow id="Flow_S2_4" sourceRef="Gateway_S2" targetRef="Task_S2_Mark" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_S2_5" sourceRef="Gateway_S2" targetRef="Task_S2_Continue" name="Non"/>
    <bpmn:sequenceFlow id="Flow_S2_6" sourceRef="Task_S2_Mark" targetRef="EndEvent_S2_Treated"/>
    <bpmn:sequenceFlow id="Flow_S2_7" sourceRef="Task_S2_Continue" targetRef="EndEvent_S2_Done"/>
    <bpmn:sequenceFlow id="Flow_S3_1" sourceRef="StartEvent_S3" targetRef="Task_S3_Wait"/>
    <bpmn:sequenceFlow id="Flow_S3_2" sourceRef="Task_S3_Wait" targetRef="Task_S3_Reason"/>
    <bpmn:sequenceFlow id="Flow_S3_3" sourceRef="Task_S3_Reason" targetRef="Task_S3_Dashboard"/>
    <bpmn:sequenceFlow id="Flow_S3_4" sourceRef="Task_S3_Dashboard" targetRef="Gateway_S3"/>
    <bpmn:sequenceFlow id="Flow_S3_5" sourceRef="Gateway_S3" targetRef="Task_S3_Resume" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_S3_6" sourceRef="Gateway_S3" targetRef="Task_S3_Maintain" name="Non"/>
    <bpmn:sequenceFlow id="Flow_S3_7" sourceRef="Task_S3_Maintain" targetRef="Gateway_S3"/>
    <bpmn:sequenceFlow id="Flow_S3_8" sourceRef="Task_S3_Resume" targetRef="EndEvent_S3"/>
    <bpmn:sequenceFlow id="Flow_S4_1" sourceRef="StartEvent_S4" targetRef="Task_S4_Signal"/>
    <bpmn:sequenceFlow id="Flow_S4_2" sourceRef="Task_S4_Signal" targetRef="Task_S4_Analyze"/>
    <bpmn:sequenceFlow id="Flow_S4_3" sourceRef="Task_S4_Analyze" targetRef="Task_S4_Replan"/>
    <bpmn:sequenceFlow id="Flow_S4_4" sourceRef="Task_S4_Replan" targetRef="EndEvent_S4"/>
    <bpmn:sequenceFlow id="Flow_S5_1" sourceRef="StartEvent_S5" targetRef="Task_S5_Select"/>
    <bpmn:sequenceFlow id="Flow_S5_2" sourceRef="Task_S5_Select" targetRef="Gateway_S5"/>
    <bpmn:sequenceFlow id="Flow_S5_3" sourceRef="Gateway_S5" targetRef="Task_S5_Validate" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_S5_4" sourceRef="Gateway_S5" targetRef="Task_S5_Complete" name="Non"/>
    <bpmn:sequenceFlow id="Flow_S5_5" sourceRef="Task_S5_Complete" targetRef="Gateway_S5"/>
    <bpmn:sequenceFlow id="Flow_S5_6" sourceRef="Task_S5_Validate" targetRef="Task_S5_Close"/>
    <bpmn:sequenceFlow id="Flow_S5_7" sourceRef="Task_S5_Close" targetRef="EndEvent_S5"/>
  </bpmn:process>
