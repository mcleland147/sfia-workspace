        <di:waypoint x="1050" y="305"/>
        <di:waypoint x="1050" y="140"/>
        <di:waypoint x="1100" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Journal_Update_di" bpmnElement="Flow_Journal_Update">
