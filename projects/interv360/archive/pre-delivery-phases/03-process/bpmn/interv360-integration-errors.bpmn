        <di:waypoint x="1550.0" y="500"/>
        <di:waypoint x="1485.0" y="460"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
