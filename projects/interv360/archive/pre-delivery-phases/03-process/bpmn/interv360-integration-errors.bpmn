        <di:waypoint x="460" y="120.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Envoyer_Traiter_di" bpmnElement="Flow_Envoyer_Traiter">
        <di:waypoint x="590" y="120.0"/>
        <di:waypoint x="575" y="140"/>
        <di:waypoint x="575" y="305"/>
        <di:waypoint x="620" y="305"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Traiter_Gateway_di" bpmnElement="Flow_Traiter_Gateway">
