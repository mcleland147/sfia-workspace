      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AnomalieSuivie_di" bpmnElement="EndEvent_AnomalieSuivie">
        <dc:Bounds x="1900" y="552" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAnnotation_ClosureLocal_di" bpmnElement="TextAnnotation_ClosureLocal">
        <dc:Bounds x="180" y="620" width="300" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAnnotation_Gravites_di" bpmnElement="TextAnnotation_Gravites">
        <dc:Bounds x="1080" y="500" width="280" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAnnotation_Retry_di" bpmnElement="TextAnnotation_Retry">
        <dc:Bounds x="1400" y="500" width="300" height="55"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Preparer_di" bpmnElement="Flow_Start_Preparer">
        <di:waypoint x="236" y="120.0"/>
        <di:waypoint x="300" y="120.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Preparer_Envoyer_di" bpmnElement="Flow_Preparer_Envoyer">
