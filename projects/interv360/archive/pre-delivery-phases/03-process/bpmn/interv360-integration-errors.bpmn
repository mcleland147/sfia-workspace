<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Interv360IntegrationErrors" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.31.0">
  <bpmn:collaboration id="Collaboration_Interv360IntegrationErrors">
    <bpmn:participant id="Participant_IntegrationErrors" name="Interv360 Integration Errors" processRef="Process_Interv360_Integration_Errors"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Interv360_Integration_Errors" name="Interv360 Integration Errors" isExecutable="false">
    <bpmn:laneSet id="LaneSet_IntegrationErrors">
      <bpmn:lane id="Lane_Interv360" name="Interv360">
        <bpmn:flowNodeRef>StartEvent_ClosureLocal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PreparerSync</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnvoyerCrm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreerAnomalie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_JournalSucces</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_JournalReprise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_JournalAnomalie</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CrmSimule" name="CRM simulé / intégration">
        <bpmn:flowNodeRef>Task_TraiterSync</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SyncOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmerSync</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ManagerSav" name="Manager SAV">
        <bpmn:flowNodeRef>Task_QualifierGravite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RepriseManuelle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CorrigerRelancer</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Dashboard" name="Dashboard / pilotage">
        <bpmn:flowNodeRef>Task_UpdateDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SyncDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AfficherDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AnomalieSuivie</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_ClosureLocal" name="Clôture locale validée">
      <bpmn:outgoing>Flow_Start_Preparer</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_PreparerSync" name="Préparer les données de synchronisation">
      <bpmn:incoming>Flow_Start_Preparer</bpmn:incoming>
      <bpmn:outgoing>Flow_Preparer_Envoyer</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnvoyerCrm" name="Envoyer la clôture au CRM simulé">
      <bpmn:incoming>Flow_Preparer_Envoyer</bpmn:incoming>
      <bpmn:incoming>Flow_Relance_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_Envoyer_Traiter</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_TraiterSync" name="Traiter la synchronisation">
      <bpmn:incoming>Flow_Envoyer_Traiter</bpmn:incoming>
      <bpmn:outgoing>Flow_Traiter_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SyncOk" name="Synchronisation réussie ?" default="Flow_Sync_Non">
      <bpmn:incoming>Flow_Traiter_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Sync_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sync_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ConfirmerSync" name="Confirmer la synchronisation">
      <bpmn:incoming>Flow_Sync_Oui</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirmer_Journal</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_JournalSucces" name="Journaliser le succès">
      <bpmn:incoming>Flow_Confirmer_Journal</bpmn:incoming>
      <bpmn:outgoing>Flow_Journal_Update</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UpdateDashboard" name="Mettre à jour le dashboard">
      <bpmn:incoming>Flow_Journal_Update</bpmn:incoming>
      <bpmn:outgoing>Flow_Update_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_SyncDone" name="Synchronisation terminée">
      <bpmn:incoming>Flow_Update_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_CreerAnomalie" name="Créer une anomalie d'intégration">
      <bpmn:incoming>Flow_Sync_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_Creer_Qualifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QualifierGravite" name="Qualifier la gravité">
      <bpmn:incoming>Flow_Creer_Qualifier</bpmn:incoming>
      <bpmn:outgoing>Flow_Qualifier_Reprise</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RepriseManuelle" name="Reprise manuelle requise ?" default="Flow_Reprise_Non">
      <bpmn:incoming>Flow_Qualifier_Reprise</bpmn:incoming>
      <bpmn:outgoing>Flow_Reprise_Oui</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reprise_Non</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CorrigerRelancer" name="Corriger les données ou relancer la sync">
      <bpmn:incoming>Flow_Reprise_Oui</bpmn:incoming>
      <bpmn:outgoing>Flow_Corriger_JournalReprise</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_JournalReprise" name="Journaliser la reprise">
      <bpmn:incoming>Flow_Corriger_JournalReprise</bpmn:incoming>
      <bpmn:outgoing>Flow_JournalReprise_Afficher</bpmn:outgoing>
      <bpmn:outgoing>Flow_Relance_Loop</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_JournalAnomalie" name="Journaliser l'anomalie">
      <bpmn:incoming>Flow_Reprise_Non</bpmn:incoming>
      <bpmn:outgoing>Flow_JournalAnomalie_Afficher</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AfficherDashboard" name="Afficher l'anomalie au dashboard">
      <bpmn:incoming>Flow_JournalReprise_Afficher</bpmn:incoming>
      <bpmn:incoming>Flow_JournalAnomalie_Afficher</bpmn:incoming>
      <bpmn:outgoing>Flow_Afficher_EndAnomalie</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_AnomalieSuivie" name="Anomalie suivie">
      <bpmn:incoming>Flow_Afficher_EndAnomalie</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_ClosureLocal">
      <bpmn:text>Clôture locale conservée : la clôture reste valide même si la sync CRM échoue. L'anomalie porte uniquement sur la synchronisation.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_Gravites">
      <bpmn:text>Gravités RG-I06 : Information ; Bloquant métier ; Bloquant sync.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_Retry">
      <bpmn:text>Retry automatique avancé hors MVP : reprise manuelle simulée.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_Closure" associationDirection="None" sourceRef="TextAnnotation_ClosureLocal" targetRef="StartEvent_ClosureLocal"/>
    <bpmn:association id="Association_Gravites" associationDirection="None" sourceRef="TextAnnotation_Gravites" targetRef="Task_QualifierGravite"/>
    <bpmn:association id="Association_Retry" associationDirection="None" sourceRef="TextAnnotation_Retry" targetRef="Task_CorrigerRelancer"/>
    <bpmn:sequenceFlow id="Flow_Start_Preparer" sourceRef="StartEvent_ClosureLocal" targetRef="Task_PreparerSync"/>
    <bpmn:sequenceFlow id="Flow_Preparer_Envoyer" sourceRef="Task_PreparerSync" targetRef="Task_EnvoyerCrm"/>
    <bpmn:sequenceFlow id="Flow_Envoyer_Traiter" sourceRef="Task_EnvoyerCrm" targetRef="Task_TraiterSync"/>
    <bpmn:sequenceFlow id="Flow_Traiter_Gateway" sourceRef="Task_TraiterSync" targetRef="Gateway_SyncOk"/>
    <bpmn:sequenceFlow id="Flow_Sync_Oui" sourceRef="Gateway_SyncOk" targetRef="Task_ConfirmerSync" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Sync_Non" sourceRef="Gateway_SyncOk" targetRef="Task_CreerAnomalie" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Confirmer_Journal" sourceRef="Task_ConfirmerSync" targetRef="Task_JournalSucces"/>
    <bpmn:sequenceFlow id="Flow_Journal_Update" sourceRef="Task_JournalSucces" targetRef="Task_UpdateDashboard"/>
    <bpmn:sequenceFlow id="Flow_Update_End" sourceRef="Task_UpdateDashboard" targetRef="EndEvent_SyncDone"/>
    <bpmn:sequenceFlow id="Flow_Creer_Qualifier" sourceRef="Task_CreerAnomalie" targetRef="Task_QualifierGravite"/>
    <bpmn:sequenceFlow id="Flow_Qualifier_Reprise" sourceRef="Task_QualifierGravite" targetRef="Gateway_RepriseManuelle"/>
    <bpmn:sequenceFlow id="Flow_Reprise_Oui" sourceRef="Gateway_RepriseManuelle" targetRef="Task_CorrigerRelancer" name="Oui"/>
    <bpmn:sequenceFlow id="Flow_Reprise_Non" sourceRef="Gateway_RepriseManuelle" targetRef="Task_JournalAnomalie" name="Non"/>
    <bpmn:sequenceFlow id="Flow_Corriger_JournalReprise" sourceRef="Task_CorrigerRelancer" targetRef="Task_JournalReprise"/>
    <bpmn:sequenceFlow id="Flow_JournalReprise_Afficher" sourceRef="Task_JournalReprise" targetRef="Task_AfficherDashboard"/>
    <bpmn:sequenceFlow id="Flow_JournalAnomalie_Afficher" sourceRef="Task_JournalAnomalie" targetRef="Task_AfficherDashboard"/>
    <bpmn:sequenceFlow id="Flow_Afficher_EndAnomalie" sourceRef="Task_AfficherDashboard" targetRef="EndEvent_AnomalieSuivie"/>
    <bpmn:sequenceFlow id="Flow_Relance_Loop" sourceRef="Task_JournalReprise" targetRef="Task_EnvoyerCrm"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_IntegrationErrors">
    <bpmndi:BPMNPlane id="BPMNPlane_IntegrationErrors" bpmnElement="Collaboration_Interv360IntegrationErrors">
      <bpmndi:BPMNShape id="Participant_di" bpmnElement="Participant_IntegrationErrors" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1920" height="600"/>
