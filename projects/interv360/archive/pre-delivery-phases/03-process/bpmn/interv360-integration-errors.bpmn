      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SyncDone_di" bpmnElement="EndEvent_SyncDone">
        <dc:Bounds x="1420" y="552" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreerAnomalie_di" bpmnElement="Task_CreerAnomalie">
        <dc:Bounds x="940" y="80" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_QualifierGravite_di" bpmnElement="Task_QualifierGravite">
        <dc:Bounds x="1100" y="380" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RepriseManuelle_di" bpmnElement="Gateway_RepriseManuelle" isMarkerVisible="true">
        <dc:Bounds x="1260" y="407" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CorrigerRelancer_di" bpmnElement="Task_CorrigerRelancer">
        <dc:Bounds x="1420" y="380" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_JournalReprise_di" bpmnElement="Task_JournalReprise">
        <dc:Bounds x="1580" y="80" width="130" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_JournalAnomalie_di" bpmnElement="Task_JournalAnomalie">
        <dc:Bounds x="1420" y="80" width="130" height="80"/>
