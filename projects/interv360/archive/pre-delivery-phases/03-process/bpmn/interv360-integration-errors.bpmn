        <di:waypoint x="805" y="355"/>
        <di:waypoint x="805" y="140"/>
        <di:waypoint x="940" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirmer_Journal_di" bpmnElement="Flow_Confirmer_Journal">
