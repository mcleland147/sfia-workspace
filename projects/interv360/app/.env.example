# Interv360 frontend configuration
#
# Default mode is local if this variable is absent or not equal to "api".
# Use "api" to connect the frontend to the local backend.
VITE_INTERV360_DATA_SOURCE=local

# Local backend API base URL used when VITE_INTERV360_DATA_SOURCE=api.
VITE_INTERV360_API_BASE_URL=http://localhost:3001/api/v1
