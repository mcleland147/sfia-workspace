# Interv360 backend configuration

# HTTP port used by the local backend.
PORT=3001

# SQLite database path.
# Relative paths are resolved from projects/interv360/backend.
SQLITE_PATH=data/interv360.sqlite

# Demo mode enables the reset endpoint POST /api/v1/demo/reset.
DEMO_MODE=true

# Comma-separated list of allowed local frontend origins.
INTERV360_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
