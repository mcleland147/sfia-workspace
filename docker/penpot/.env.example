# Penpot SFIA local template
# Copy this file to .env locally.
# Never commit .env.

PENPOT_PUBLIC_URI=http://localhost:9001
PENPOT_SECRET_KEY=CHANGE_ME_GENERATE_LOCALLY

# SMTP placeholders (optional — configure only if mail is required)
PENPOT_SMTP_DEFAULT_FROM=no-reply@example.local
PENPOT_SMTP_DEFAULT_REPLY_TO=no-reply@example.local

# Optional reverse proxy / domain
PENPOT_DOMAIN=localhost
