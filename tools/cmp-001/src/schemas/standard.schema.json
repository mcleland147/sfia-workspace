{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Standard",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "required": true,
      "notionType": "title",
      "notionProperty": "Name"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Review", "Published", "Deprecated"],
      "notionType": "status",
      "notionProperty": "Status"
    }
  }
}
