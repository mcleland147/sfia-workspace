{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "REX",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "required": true,
      "notionType": "title",
      "notionProperty": "REX"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Review", "Published", "Archived"],
      "notionType": "status",
      "notionProperty": "Status"
    },
    "impact": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"],
      "notionType": "select",
      "notionProperty": "Impact"
    },
    "date": {
      "type": "string",
      "format": "date",
      "notionType": "date",
      "notionProperty": "Date"
    },
    "tags": {
      "type": "array",
      "items": "string",
      "notionType": "multi_select",
      "notionProperty": "Tags"
    }
  }
}
